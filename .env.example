# Copy to .env and fill in real values. .env is gitignored.

# PostgreSQL
POSTGRES_USER=chaosmend
POSTGRES_PASSWORD=change_me
POSTGRES_DB=chaosmend
DATABASE_URL=postgresql://chaosmend:change_me@postgres:5432/chaosmend

# Kafka
KAFKA_BOOTSTRAP_SERVERS=kafka:9092

# Service ports (internal Docker network)
TRANSACTION_PORT=8001
RISK_PORT=8002
NOTIFICATION_PORT=8003
ANALYTICS_PORT=8004
CHAOS_PORT=8005
ANOMALY_PORT=8006
HEALING_PORT=8007

# Monitoring
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
