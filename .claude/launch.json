    },
    {
      "name": "Healing Agent",
      "runtimeExecutable": "uvicorn",
      "runtimeArgs": ["main:app", "--host", "0.0.0.0", "--port", "8007", "--reload", "--app-dir", "healing_agent"],
      "port": 8007
    }
  ]
}
