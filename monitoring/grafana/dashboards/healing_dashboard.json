{
  "__inputs": [],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.1.0" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" }
  ],
  "annotations": { "list": [] },
  "description": "ChaosMend – Self-Healing Agent Dashboard",
  "editable": true,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [

    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 200,
      "title": "Key Performance Indicators",
      "type": "row"
    },

    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "red",    "value": null },
            { "color": "yellow", "value": 50   },
            { "color": "green",  "value": 80   }
          ]},
          "unit": "percent",
          "min": 0, "max": 100
        }, "overrides": []
      },
      "gridPos": { "h": 5, "w": 5, "x": 0, "y": 1 },
      "id": 1,
      "options": {
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      },
      "title": "Healing Success Rate",
      "type": "gauge",
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "expr": "100 * sum(healing_successes_total) / (sum(healing_successes_total) + sum(healing_failures_total) + 0.001)",
        "legendFormat": "Success %",
        "refId": "A"
      }]
    },

    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green",  "value": null  },
            { "color": "yellow", "value": 90    },
            { "color": "red",    "value": 120   }
          ]},
          "unit": "s"
        }, "overrides": []
      },
      "gridPos": { "h": 5, "w": 5, "x": 5, "y": 1 },
      "id": 2,
      "options": { "colorMode": "background", "graphMode": "none", "justifyMode": "center", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "title": "Mean Time To Recovery (MTTR)",
      "type": "stat",
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "expr": "histogram_quantile(0.50, rate(healing_recovery_time_seconds_bucket[1h]))",
        "legendFormat": "MTTR p50",
        "refId": "A"
      }]
    },

    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green",  "value": null },
            { "color": "yellow", "value": 10   },
            { "color": "red",    "value": 50   }
          ]},
          "unit": "short"
        }, "overrides": []
      },
      "gridPos": { "h": 5, "w": 4, "x": 10, "y": 1 },
      "id": 3,
      "options": { "colorMode": "value", "graphMode": "area", "justifyMode": "center", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "title": "Total Heals",
      "type": "stat",
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "expr": "sum(healing_actions_total)",
        "legendFormat": "Total",
        "refId": "A"
      }]
    },

    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "red",   "value": 1    }
          ]},
          "unit": "short"
        }, "overrides": []
      },
      "gridPos": { "h": 5, "w": 5, "x": 14, "y": 1 },
      "id": 4,
      "options": { "colorMode": "background", "graphMode": "none", "justifyMode": "center", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "title": "Circuit Breakers Open",
      "type": "stat",
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "expr": "sum(healing_circuit_breaker_open)",
        "legendFormat": "Open breakers",
        "refId": "A"
      }]
    },

    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null }
          ]},
          "unit": "short"
        }, "overrides": []
      },
      "gridPos": { "h": 5, "w": 5, "x": 19, "y": 1 },
      "id": 5,
      "options": { "colorMode": "value", "graphMode": "area", "justifyMode": "center", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "title": "Anomalies Received",
      "type": "stat",
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "expr": "sum(healing_anomalies_received_total)",
        "legendFormat": "Anomalies",
        "refId": "A"
      }]
    },

    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 6 },
      "id": 201,
      "title": "Healing Activity Over Time",
      "type": "row"
    },

    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "bars", "fillOpacity": 80, "lineWidth": 1,
            "stacking": { "group": "A", "mode": "none" } },
          "unit": "short"
        }, "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 7 },
      "id": 6,
      "options": {
        "legend": { "calcs": ["sum"], "displayMode": "table", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "none" }
      },
      "title": "Healing Actions per Minute (by Action Type)",
      "type": "timeseries",
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "rate(healing_actions_total{action=\"restart_container\"}[5m]) * 60", "legendFormat": "restart_container", "refId": "A" },
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "rate(healing_actions_total{action=\"scale_up\"}[5m]) * 60",          "legendFormat": "scale_up",          "refId": "B" },
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "rate(healing_actions_total{action=\"rate_limit\"}[5m]) * 60",         "legendFormat": "rate_limit",         "refId": "C" },
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "rate(healing_actions_total{action=\"circuit_breaker\"}[5m]) * 60",    "legendFormat": "circuit_breaker",    "refId": "D" },
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "rate(healing_actions_total{action=\"alert\"}[5m]) * 60",              "legendFormat": "alert",              "refId": "E" }
      ]
    },

    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "line", "fillOpacity": 20, "lineWidth": 2 },
          "unit": "short"
        }, "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 7 },
      "id": 7,
      "options": {
        "legend": { "calcs": ["sum"], "displayMode": "table", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "none" }
      },
      "title": "Healing Success vs Failure Rate",
      "type": "timeseries",
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "rate(healing_successes_total[5m]) * 60", "legendFormat": "successes/min", "refId": "A" },
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "rate(healing_failures_total[5m]) * 60",  "legendFormat": "failures/min",  "refId": "B" }
      ]
    },

    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 15 },
      "id": 202,
      "title": "Recovery Time Distribution",
      "type": "row"
    },

    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "line", "fillOpacity": 10, "lineWidth": 2 },
          "unit": "s"
        }, "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "id": 8,
      "options": {
        "legend": { "calcs": ["lastNotNull"], "displayMode": "table", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "none" }
      },
      "title": "Recovery Time Percentiles (MTTR)",
      "type": "timeseries",
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "histogram_quantile(0.50, rate(healing_recovery_time_seconds_bucket[30m]))", "legendFormat": "p50", "refId": "A" },
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "histogram_quantile(0.90, rate(healing_recovery_time_seconds_bucket[30m]))", "legendFormat": "p90", "refId": "B" },
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "histogram_quantile(0.99, rate(healing_recovery_time_seconds_bucket[30m]))", "legendFormat": "p99", "refId": "C" }
      ]
    },

    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "line", "fillOpacity": 10, "lineWidth": 2 },
          "unit": "short"
        }, "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "id": 9,
      "options": {
        "legend": { "calcs": ["lastNotNull"], "displayMode": "table", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "none" }
      },
      "title": "Anomaly Events by Source (Kafka vs REST Poll)",
      "type": "timeseries",
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "rate(healing_anomalies_received_total{source=\"kafka\"}[5m]) * 60",     "legendFormat": "kafka (real-time)",  "refId": "A" },
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "rate(healing_anomalies_received_total{source=\"rest_poll\"}[5m]) * 60", "legendFormat": "rest_poll (fallback)","refId": "B" }
      ]
    },

    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 24 },
      "id": 203,
      "title": "Circuit Breaker & Severity Breakdown",
      "type": "row"
    },

    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "red",   "value": 1    }
          ]},
          "mappings": [{ "options": { "0": { "text": "CLOSED" }, "1": { "text": "OPEN" } }, "type": "value" }],
          "unit": "short"
        }, "overrides": []
      },
      "gridPos": { "h": 6, "w": 8, "x": 0, "y": 25 },
      "id": 10,
      "options": {
        "colorMode": "background", "graphMode": "none",
        "justifyMode": "center",
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "text": {}
      },
      "title": "Circuit Breaker Status (per service)",
      "type": "stat",
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "expr": "healing_circuit_breaker_open",
        "legendFormat": "{{service}}",
        "refId": "A"
      }]
    },

    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "bars", "fillOpacity": 80, "lineWidth": 1 },
          "unit": "short"
        }, "overrides": []
      },
      "gridPos": { "h": 6, "w": 8, "x": 8, "y": 25 },
      "id": 11,
      "options": {
        "legend": { "calcs": ["sum"], "displayMode": "table", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "none" }
      },
      "title": "Actions by Anomaly Severity",
      "type": "timeseries",
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "rate(healing_actions_total{severity=\"HIGH\"}[5m]) * 60",   "legendFormat": "HIGH severity",   "refId": "A" },
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "rate(healing_actions_total{severity=\"MEDIUM\"}[5m]) * 60", "legendFormat": "MEDIUM severity", "refId": "B" }
      ]
    },

    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "line", "fillOpacity": 10, "lineWidth": 2 },
          "unit": "short"
        }, "overrides": []
      },
      "gridPos": { "h": 6, "w": 8, "x": 16, "y": 25 },
      "id": 12,
      "options": {
        "legend": { "calcs": ["sum"], "displayMode": "table", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "none" }
      },
      "title": "Actions by Anomaly State (Q-table state)",
      "type": "timeseries",
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "rate(healing_actions_total{state=\"cpu_high\"}[5m]) * 60",        "legendFormat": "cpu_high",        "refId": "A" },
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "rate(healing_actions_total{state=\"memory_high\"}[5m]) * 60",     "legendFormat": "memory_high",     "refId": "B" },
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "rate(healing_actions_total{state=\"error_rate_high\"}[5m]) * 60", "legendFormat": "error_rate_high", "refId": "C" },
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "rate(healing_actions_total{state=\"latency_high\"}[5m]) * 60",    "legendFormat": "latency_high",    "refId": "D" },
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "rate(healing_actions_total{state=\"kafka_lag_high\"}[5m]) * 60",  "legendFormat": "kafka_lag_high",  "refId": "E" },
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "rate(healing_actions_total{state=\"risk_high\"}[5m]) * 60",       "legendFormat": "risk_high",       "refId": "F" }
      ]
    }

  ],
  "refresh": "10s",
  "schemaVersion": 38,
  "tags": ["chaosmend", "healing", "rl"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "ChaosMend – Self-Healing Agent",
  "uid": "chaosmend-healing",
  "version": 1
}
